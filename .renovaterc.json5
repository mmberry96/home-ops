{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'helpers:pinGitHubActionDigests',
    'github>home-operations/renovate-presets#1.0.0',
    'github>mmberry96/home-ops//.renovate/autoMerge.json5',
    'github>mmberry96/home-ops//.renovate/groups.json5',
    'github>mmberry96/home-ops//.renovate/labels.json5',
    ':automergeBranch',
    ':disableRateLimiting',
    ':semanticCommits',
    ':timezone(America/Chicago)'
  ],
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  ignorePaths: ['**/resources/**']
}
